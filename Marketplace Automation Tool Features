      "text": "This is a comprehensive technical blueprint and implementation guide for your **MarketFlow AI** platform. Given the scale, I will provide the core architecture, the essential React components for the 5-step wizard, and the backend integration logic for the AI Market Detection.\n\n### 1. Project Structure\n```text\n/src\n  /api             # Backend Express routes \u0026 AI logic\n  /components      # Reusable UI (Button, Input, Dropzone)\n  /context         # Session \u0026 Auth state management\n  /features        # Core modules (Upload, Detect, Process, Export, Share)\n  /hooks           # Custom hooks (useProcessing, useMarketDetect)\n  /services        # Firebase \u0026 Gemini API config\n  /types           # TypeScript interfaces (Session, FileAsset, etc.)\n  App.tsx          # Main Router \u0026 Layout\n```\n\n### 2. Data Models (Typescript)\n`src/types/index.ts`\n```typescript\nexport interface Market {\n  name: string;\n  platform: \u0027eBay\u0027 | \u0027Etsy\u0027 | \u0027Amazon\u0027 | \u0027Shopify\u0027 | \u0027Social\u0027;\n  confidenceScore: number;\n  suggestedPrice: number;\n  tags: string[];\n}\n\nexport interface FileAsset {\n  id: string;\n  sessionId: string;\n  originalName: string;\n  type: \u0027image\u0027 | \u0027video\u0027 | \u0027document\u0027;\n  storageUrl: string;\n  thumbnailUrl: string;\n  detectedCategory?: string;\n  processingStatus: \u0027pending\u0027 | \u0027processing\u0027 | \u0027done\u0027 | \u0027error\u0027;\n  processedOutputs: string[]; // URLs\n}\n\nexport interface Session {\n  id: string;\n  userId: string;\n  name: string;\n  createdAt: number;\n  status: \u0027uploading\u0027 | \u0027detecting\u0027 | \u0027processing\u0027 | \u0027complete\u0027;\n  detectedMarkets: Market[];\n  files: FileAsset[];\n}\n```\n\n### 3. Step 1 \u0026 2: File Unloader \u0026 Detect Engine\nThis component handles the drag-and-drop and triggers the AI analysis via a backend proxy.\n\n`src/features/Upload/UploadZone.tsx`\n```tsx\nimport React, { useCallback, useState } from \u0027react\u0027;\nimport { useDropzone } from \u0027react-dropzone\u0027;\nimport { storage } from \u0027../../services/firebase\u0027;\nimport { ref, uploadBytesResumable, getDownloadURL } from \u0027firebase/storage\u0027;\nimport { Upload, FileText, Image as ImageIcon, Loader2 } from \u0027lucide-react\u0027;\n\nexport const UploadZone \u003d ({ sessionId, onComplete }: { sessionId: string, onComplete: () \u003d\u003e void }) \u003d\u003e {\n  const [uploads, setUploads] \u003d useState\u003cRecord\u003cstring, number\u003e\u003e({});\n\n  const onDrop \u003d useCallback(async (acceptedFiles: File[]) \u003d\u003e {\n    const uploadPromises \u003d acceptedFiles.map(async (file) \u003d\u003e {\n      const storageRef \u003d ref(storage, `uploads/${sessionId}/${file.name}`);\n      const uploadTask \u003d uploadBytesResumable(storageRef, file);\n\n      return new Promise((resolve, reject) \u003d\u003e {\n        uploadTask.on(\u0027state_changed\u0027, \n          (snapshot) \u003d\u003e {\n            const progress \u003d (snapshot.bytesTransferred / snapshot.totalBytes) * 100;\n            setUploads(prev \u003d\u003e ({ ...prev, [file.name]: progress }));\n          },\n          reject,\n          async () \u003d\u003e {\n            const url \u003d await getDownloadURL(uploadTask.snapshot.ref);\n            // Call Backend to save FileAsset to Firestore\n            resolve(url);\n          }\n        );\n      });\n    });\n\n    await Promise.all(uploadPromises);\n    onComplete();\n  }, [sessionId]);\n\n  const { getRootProps, getInputProps, isDragActive } \u003d useDropzone({ onDrop });\n\n  return (\n    \u003cdiv {...getRootProps()} className\u003d\"border-2 border-dashed border-slate-700 rounded-xl p-12 bg-slate-900/50 hover:bg-slate-800/50 transition-all cursor-pointer\"\u003e\n      \u003cinput {...getInputProps()} /\u003e\n      \u003cdiv className\u003d\"flex flex-col items-center\"\u003e\n        \u003cUpload className\u003d\"w-12 h-12 text-blue-500 mb-4\" /\u003e\n        \u003cp className\u003d\"text-lg font-medium\"\u003eDrag \u0026 drop product assets\u003c/p\u003e\n        \u003cp className\u003d\"text-slate-400 text-sm\"\u003eImages, Videos, PDFs (Max 50 files)\u003c/p\u003e\n      \u003c/div\u003e\n      \n      {Object.keys(uploads).length \u003e 0 \u0026\u0026 (\n        \u003cdiv className\u003d\"mt-8 space-y-2\"\u003e\n          {Object.entries(uploads).map(([name, progress]) \u003d\u003e (\n            \u003cdiv key\u003d{name} className\u003d\"w-full bg-slate-800 rounded-full h-2\"\u003e\n              \u003cdiv className\u003d\"bg-blue-600 h-2 rounded-full\" style\u003d{{ width: `${progress}%` }} /\u003e\n            \u003c/div\u003e\n          ))}\n        \u003c/div\u003e\n      )}\n    \u003c/div\u003e\n  );\n};\n```\n\n### 4. Step 3: Processing Sidebar Controls\n`src/features/Process/ControlsSidebar.tsx`\n```tsx\nimport React from \u0027react\u0027;\nimport * as Switch from \u0027@radix-ui/react-switch\u0027;\n\nexport const ControlsSidebar \u003d ({ config, setConfig }: any) \u003d\u003e {\n  return (\n    \u003caside className\u003d\"w-80 border-r border-slate-800 p-6 h-full bg-slate-950 overflow-y-auto\"\u003e\n      \u003ch2 className\u003d\"text-xl font-bold mb-6\"\u003eProcessing Controls\u003c/h2\u003e\n      \n      \u003cdiv className\u003d\"space-y-6\"\u003e\n        \u003csection\u003e\n          \u003clabel className\u003d\"text-sm font-semibold text-slate-400 uppercase\"\u003eAI Content\u003c/label\u003e\n          \u003cdiv className\u003d\"mt-3 space-y-4\"\u003e\n            \u003cbutton className\u003d\"w-full bg-slate-800 p-3 rounded-lg text-left hover:bg-slate-700\"\u003e\n              Generate SEO Title\n            \u003c/button\u003e\n            \u003cbutton className\u003d\"w-full bg-slate-800 p-3 rounded-lg text-left hover:bg-slate-700\"\u003e\n              Write Description\n            \u003c/button\u003e\n          \u003c/div\u003e\n        \u003c/section\u003e\n\n        \u003csection\u003e\n          \u003clabel className\u003d\"text-sm font-semibold text-slate-400 uppercase\"\u003eImage Enhancements\u003c/label\u003e\n          \u003cdiv className\u003d\"mt-3 flex items-center justify-between\"\u003e\n            \u003cspan\u003eBackground Removal\u003c/span\u003e\n            \u003cSwitch.Root className\u003d\"w-11 h-6 bg-slate-700 rounded-full relative data-[state\u003dchecked]:bg-blue-600\"\u003e\n              \u003cSwitch.Thumb className\u003d\"block w-5 h-5 bg-white rounded-full transition-transform translate-x-0.5 data-[state\u003dchecked]:translate-x-[20px]\" /\u003e\n            \u003c/Switch.Root\u003e\n          \u003c/div\u003e\n        \u003c/section\u003e\n\n        \u003csection\u003e\n          \u003clabel className\u003d\"text-sm font-semibold text-slate-400 uppercase\"\u003eWatermark\u003c/label\u003e\n          \u003cinput \n            type\u003d\"text\" \n            placeholder\u003d\"Custom text...\"\n            className\u003d\"w-full mt-2 bg-slate-900 border border-slate-700 p-2 rounded\"\n          /\u003e\n        \u003c/section\u003e\n\n        \u003cbutton className\u003d\"w-full bg-blue-600 hover:bg-blue-500 py-4 rounded-xl font-bold shadow-lg shadow-blue-500/20\"\u003e\n          Process Assets\n        \u003c/button\u003e\n      \u003c/div\u003e\n    \u003c/aside\u003e\n  );\n};\n```\n\n### 5. Backend: Market Detection Logic (Gemini 1.5)\nThis Express route uses the Gemini Pro Vision model to analyze the image and return a JSON market analysis.\n\n`server/routes/detect.ts`\n```typescript\nimport { GoogleGenerativeAI } from \"@google/generative-ai\";\n\nconst genAI \u003d new GoogleGenerativeAI(process.env.GEMINI_API_KEY);\n\nexport const analyzeMarket \u003d async (imageUrl: string) \u003d\u003e {\n  const model \u003d genAI.getGenerativeModel({ model: \"gemini-1.5-pro\" });\n\n  const prompt \u003d `\n    Analyze this product image. Provide a JSON response:\n    {\n      \"category\": \"string\",\n      \"bestMarkets\": [{ \"name\": \"Etsy\", \"confidence\": 95, \"reason\": \"Handmade look\" }],\n      \"suggestedPrice\": number,\n      \"seoTags\": [\"string\"],\n      \"targetAudience\": \"string\"\n    }\n  `;\n\n  // Fetch image as inlineData and send to Gemini\n  const result \u003d await model.generateContent([prompt, { inlineData: { data: base64Img, mimeType: \"image/jpeg\" } }]);\n  const response \u003d await result.response;\n  return JSON.parse(response.text());\n};\n```\n\n### 6. Step 4: Client-Side ZIP Export\nUsing `JSZip` to bundle assets without overloading the server.\n\n`src/hooks/useExport.ts`\n```typescript\nimport JSZip from \u0027jszip\u0027;\nimport { saveAs } from \u0027file-saver\u0027;\n\nexport const useExport \u003d () \u003d\u003e {\n  const exportAll \u003d async (files: FileAsset[], sessionName: string) \u003d\u003e {\n    const zip \u003d new JSZip();\n    const folder \u003d zip.folder(sessionName);\n\n    const downloadPromises \u003d files.map(async (file) \u003d\u003e {\n      const response \u003d await fetch(file.storageUrl);\n      const blob \u003d await response.blob();\n      folder?.file(file.originalName, blob);\n    });\n\n    await Promise.all(downloadPromises);\n    const content \u003d await zip.generateAsync({ type: \"blob\" });\n    saveAs(content, `${sessionName}-marketflow-export.zip`);\n  };\n\n  return { exportAll };\n};\n```\n\n### 7. Core Application Layout (Main Wrapper)\n`src/App.tsx`\n```tsx\nimport { Sidebar } from \u0027./components/Navigation/Sidebar\u0027;\nimport { TopBar } from \u0027./components/Navigation/TopBar\u0027;\nimport { StepIndicator } from \u0027./components/Wizard/StepIndicator\u0027;\n\nconst App \u003d () \u003d\u003e {\n  const [step, setStep] \u003d useState(1);\n\n  return (\n    \u003cdiv className\u003d\"flex h-screen bg-black text-white overflow-hidden\"\u003e\n      \u003cSidebar /\u003e\n      \n      \u003cmain className\u003d\"flex-1 flex flex-col relative\"\u003e\n        \u003cTopBar /\u003e\n        \u003cStepIndicator currentStep\u003d{step} /\u003e\n        \n        \u003cdiv className\u003d\"flex-1 overflow-auto p-8\"\u003e\n          {step \u003d\u003d\u003d 1 \u0026\u0026 \u003cUploadZone onComplete\u003d{() \u003d\u003e setStep(2)} /\u003e}\n          {step \u003d\u003d\u003d 2 \u0026\u0026 \u003cMarketDetectionView onProceed\u003d{() \u003d\u003e setStep(3)} /\u003e}\n          {step \u003d\u003d\u003d 3 \u0026\u0026 \u003cProcessingLayout /\u003e}\n          {step \u003d\u003d\u003d 4 \u0026\u0026 \u003cExportGallery /\u003e}\n          {step \u003d\u003d\u003d 5 \u0026\u0026 \u003cShareHub /\u003e}\n        \u003c/div\u003e\n      \u003c/main\u003e\n    \u003c/div\u003e\n  );\n};\n```\n\n### Critical Implementation Notes:\n1.  **AI Rate Limiting:** Since Gemini 1.5 Pro has limits, implement a `p-limit` on the backend to process only 3 images concurrently if a batch of 50 is uploaded.\n2.  **Web Workers:** For the Image Enhancer toggle (background removal), consider using `@imgly/background-removal` which runs in-browser via WASM to save server costs.\n3.  **Firebase Security:** Ensure your Firestore rules only allow `request.auth.uid \u003d\u003d resource.data.userId` for session access.\n4.  **Real-time Logs:** Use a `Subject` or `EventEmitter` in your processing service to push status updates to the \"Live processing log\" UI component.\n\nTo get started, initialize your project with `vite`, install dependencies (`firebase`, `lucide-react`, `jszip`, `framer-motion`, `@tanstack/react-query`), and set up your Firebase console with Storage and Firestore enabled.",
